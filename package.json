{
  "name": "aeroflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev apps/web",
    "build": "next build apps/web",
    "start": "next start apps/web",
    "typecheck": "next typegen apps/web && tsc -p apps/web/tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "seed:dev": "node backend/prisma/seed.cjs",
    "test": "vitest run --config apps/web/vitest.config.ts",
    "test:watch": "vitest --config apps/web/vitest.config.ts"
  },
  "prisma": {
    "seed": "node backend/prisma/seed.cjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.9.0",
    "@tmcw/togeojson": "^7.1.2",
    "@types/pdfkit": "^0.17.6",
    "@watergis/maplibre-gl-terradraw": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "dxf-parser": "^1.1.2",
    "dxf-writer": "^1.18.4",
    "jszip": "^3.10.1",
    "maplibre-gl": "^4.7.1",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.19.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^6.12.4",
    "tokml": "^0.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
