# ─── Database ───────────────────────────────────────────────
# SQLite (local dev, default)
DATABASE_URL="file:./data/aeroflow.db"
#
# PostgreSQL + PostGIS (producción — requiere docker-compose up -d)
# DATABASE_URL="postgresql://geo_registros:geo_registros@localhost:5432/geo_registros"

NEXT_PUBLIC_APP_NAME="AeroFlow"
STORAGE_ROOT="./storage/documents"

# ─── Auth ────────────────────────────────────────────────────
AUTH_SECRET="change-me-generate-a-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ─── Dev bootstrap ──────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@aeroflow.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_FULL_NAME="Admin AeroFlow"

# ─── Email (Resend) ─────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@aeroflow.app"
